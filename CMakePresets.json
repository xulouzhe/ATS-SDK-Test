      "inherits": "vs2022-Win32",
      "cacheVariables": {
        "ATS_SDK_ROOT": "C:/AlazarTech/ATS-SDK/7.4.0"
      }
    },
    {
      "name": "vs2022-x64",
      "displayName": "Visual Studio 2022 — x64 (kept for reference)",
      "description": "64-bit build. Not needed for the current goal but available if you want to compare.",
      "generator": "Visual Studio 17 2022",
      "architecture": { "value": "x64", "strategy": "set" },
      "binaryDir": "${sourceDir}/build-x64",
      "cacheVariables": {
        "CMAKE_CONFIGURATION_TYPES": "Debug;Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "vs2022-Win32-release",
