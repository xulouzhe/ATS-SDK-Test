{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },
  "configurePresets": [
    {
      "name": "vs2022-Win32",
      "displayName": "Visual Studio 2022 — Win32 (x86, default)",
      "description": "32-bit build — use this if you plan to merge into a Win32-only legacy project.",
      "generator": "Visual Studio 17 2022",
      "architecture": { "value": "Win32", "strategy": "set" },
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_CONFIGURATION_TYPES": "Debug;Release"
      }
    },
    {
      "name": "vs2022-Win32-sdk-override",
